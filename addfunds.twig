{% include 'ht.twig' %}

<style>
    /* تخصيص الألوان لتناسب husseinomran.sy (برتقالي وأسود) */
    :root {
        --primary-orange: #ff8c00;
        --dark-bg: #1a1a1a;
        --card-bg: #242424;
        --text-white: #ffffff;
        --text-gray: #b0b0b0;
        --success-green: #28a745;
        --danger-red: #dc3545;
        --info-blue: #17a2b8;
    }

    .app-content {
        background-color: var(--dark-bg);
        color: var(--text-white);
        min-height: 100vh;
        padding-bottom: 50px;
    }

    #PageTitle {
        color: var(--primary-orange);
        font-weight: bold;
        padding: 20px 0;
        font-size: 24px;
    }

    .card-border {
        border: 1px solid #333 !important;
        background-color: var(--card-bg) !important;
        border-radius: 15px !important;
        overflow: hidden;
    }

    .dashboard-head {
        background: linear-gradient(135deg, #2c2c2c 0%, #1a1a1a 100%);
        border: 1px solid var(--primary-orange);
    }

    .dashboard-head .title {
        color: var(--primary-orange) !important;
    }

    .dashboard-head .text {
        color: var(--text-gray) !important;
    }

    .af-text {
        color: var(--text-white) !important;
    }

    .dh-icon {
        background: rgba(255, 140, 0, 0.1) !important;
        color: var(--primary-orange) !important;
        border: 1px solid rgba(255, 140, 0, 0.3);
    }

    .card-header-premium {
        background: linear-gradient(90deg, var(--primary-orange), #e67e00) !important;
        color: white !important;
        padding: 15px;
        font-weight: bold;
    }

    .form-control-premium {
        background-color: #333 !important;
        border: 1px solid #444 !important;
        color: white !important;
        border-radius: 8px !important;
    }

    .form-control-premium:focus {
        border-color: var(--primary-orange) !important;
        box-shadow: 0 0 0 0.2rem rgba(255, 140, 0, 0.25) !important;
    }

    .label-premium {
        color: var(--primary-orange) !important;
        font-weight: 600;
        margin-bottom: 8px;
        display: block;
    }

    .currency-btn-enhanced {
        background: #333;
        border: 1px solid #444;
        color: white;
        transition: 0.3s;
    }

    .currency-btn-enhanced.active {
        background: var(--primary-orange) !important;
        border-color: var(--primary-orange) !important;
        color: white !important;
    }

    .btn-premium-submit {
        background: var(--primary-orange) !important;
        border: none !important;
        color: white !important;
        font-weight: bold !important;
        padding: 12px !important;
        border-radius: 10px !important;
        transition: 0.3s !important;
    }

    .btn-premium-submit:hover {
        background: #e67e00 !important;
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(255, 140, 0, 0.3);
    }

    .exchange-info-box {
        background: rgba(255, 140, 0, 0.05);
        border: 1px dashed var(--primary-orange);
        border-radius: 10px;
        padding: 15px;
    }

    .exchange-value {
        background: #444 !important;
        color: var(--primary-orange) !important;
        font-weight: bold;
    }

    .copy-btn {
        background: var(--primary-orange) !important;
    }

    .payment-history-item {
        background: #2c2c2c;
        border-left: 4px solid var(--primary-orange);
        margin-bottom: 10px;
        padding: 15px;
        border-radius: 8px;
    }

    .status-pending { color: var(--info-blue); }
    .status-approved { color: var(--success-green); }
    .status-rejected { color: var(--danger-red); }

    .notification {
        background: #333;
        border-right: 5px solid var(--primary-orange);
        color: white;
    }

    /* تحسينات إضافية للسجل */
    .payment-header { display: flex; justify-content: space-between; margin-bottom: 10px; }
    .payment-date { font-size: 12px; color: var(--text-gray); }
    .amount-value { font-size: 18px; font-weight: bold; color: var(--primary-orange); }
</style>

<div class="app-content">
    <div id="PageTitle">إضافة رصيد - Hussein Omran</div>
    <div class="container-fluid">
        <div id="notificationContainer" class="notification-container"></div>

        <!-- رأس الصفحة -->
        <section class="dashboard-head-wrapper">
            <div class="dashboard-head card-border p-4 d-flex align-items-center gap-4">
                <img src="https://husseinomran.sy/assets/images/logo.png" onerror="this.src='https://cdn.mypanel.link/dfdhtt/csmxfekk7q5ypwxa.png'" class="mascot-img" style="width: 80px;" />
                <div class="dhead-body">
                    <h2 class="title">💰 شحن المحفظة</h2>
                    <p class="text">أهلاً بك في Hussein Omran. اختر وسيلة الدفع المناسبة لك لشحن رصيدك فوراً.</p>
                </div>
            </div>
        </section>

        <section class="mt-4">
            <div class="row">
                <!-- نموذج الدفع -->
                <div class="col-lg-6 mb-4">
                    <div class="card card-border">
                        <div class="card-header-premium">
                            <i class="ri-bank-card-line"></i> تفاصيل الإيداع
                        </div>
                        <div class="card-body p-4">
                            <form id="addFundsForm" enctype="multipart/form-data">
                                <!-- اختيار الطريقة -->
                                <div class="form-group mb-4">
                                    <label class="label-premium">وسيلة الدفع</label>
                                    <select class="form-control form-control-premium" id="payment_method" required onchange="updatePaymentUI()">
                                        <option value="">-- اختر وسيلة الدفع --</option>
                                        <option value="syriacash">🇸🇾 Syriacash</option>
                                        <option value="syriatelecom">📱 Syriatel Cash</option>
                                        <option value="shamcash">💰 Sham Cash</option>
                                        <option value="haram">🏦 مركز هرم للحوالات</option>
                                        <option value="fouad">🏦 مركز فؤاد للحوالات</option>
                                        <option value="qadmos">🏦 مركز القدموس للحوالات</option>
                                        <option value="binance">₿ Binance (USDT)</option>
                                    </select>
                                </div>

                                <!-- اختيار العملة -->
                                <div class="form-group mb-4">
                                    <label class="label-premium">العملة المستخدمة</label>
                                    <div class="d-flex gap-2">
                                        <button type="button" class="btn currency-btn-enhanced flex-fill active" data-currency="usd" onclick="switchCurrency('usd')">USD $</button>
                                        <button type="button" class="btn currency-btn-enhanced flex-fill" data-currency="syp" onclick="switchCurrency('syp')">SYP ل.س</button>
                                    </div>
                                    <input type="hidden" id="currency_type" value="usd">
                                </div>

                                <!-- المبلغ -->
                                <div class="form-group mb-4">
                                    <label class="label-premium">المبلغ المراد شحنه</label>
                                    <div class="input-group">
                                        <input type="number" id="payment_amount" class="form-control form-control-premium" placeholder="0.00" step="0.01" required oninput="updateCurrencyCalculation()">
                                        <span class="input-group-text bg-dark text-orange border-0" id="currencySymbol" style="color: var(--primary-orange)">$</span>
                                    </div>
                                </div>

                                <!-- حاسبة العملات -->
                                <div id="currencyCalcBox" class="mb-4 p-3 rounded" style="display: none; background: #333; border: 1px solid #444;">
                                    <div class="d-flex justify-content-between small">
                                        <span>سعر الصرف التقديري:</span>
                                        <span id="exchangeRate" class="text-orange">1 USD = 15,000 SYP</span>
                                    </div>
                                    <div class="d-flex justify-content-between font-weight-bold mt-1">
                                        <span>المبلغ المقابل:</span>
                                        <span id="localAmount" class="text-orange">-</span>
                                    </div>
                                </div>

                                <!-- بيانات التحويل -->
                                <div id="exchangePaymentInfo" class="mb-4" style="display: none;">
                                    <label class="label-premium">بيانات التحويل الخاصة بنا</label>
                                    <div class="exchange-info-box">
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <span class="small text-gray">الرقم:</span>
                                            <div class="d-flex align-items-center gap-2">
                                                <span id="exchangePhone" class="exchange-value px-2 rounded">09XXXXXXXX</span>
                                                <button type="button" class="btn btn-sm copy-btn text-white" onclick="copyToClipboard(document.getElementById('exchangePhone').textContent)"><i class="ri-file-copy-line"></i></button>
                                            </div>
                                        </div>
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <span class="small text-gray">الاسم:</span>
                                            <span id="exchangeName" class="text-white">Hussein Omran</span>
                                        </div>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <span class="small text-gray">المنطقة:</span>
                                            <span id="exchangeRegion" class="text-white">سوريا</span>
                                        </div>
                                    </div>
                                </div>

                                <!-- رفع الإيصال -->
                                <div class="form-group mb-4">
                                    <label class="label-premium">صورة إيصال التحويل</label>
                                    <div class="upload-area p-4 text-center rounded" style="border: 2px dashed #444; cursor: pointer;" onclick="document.getElementById('receipt_image').click()">
                                        <input type="file" id="receipt_image" accept="image/*" style="display: none;" onchange="handleFileSelect(event)">
                                        <div id="uploadPlaceholder">
                                            <i class="ri-upload-cloud-2-line" style="font-size: 30px; color: var(--primary-orange)"></i>
                                            <p class="mb-0 mt-2 small text-gray">اضغط لرفع صورة الإيصال</p>
                                        </div>
                                        <div id="fileNameDisplay" style="display: none;">
                                            <i class="ri-checkbox-circle-line text-success"></i>
                                            <span id="fileName" class="small"></span>
                                        </div>
                                    </div>
                                </div>

                                <button type="submit" class="btn btn-premium-submit w-100">إرسال طلب الشحن</button>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- سجل الدفعات -->
                <div class="col-lg-6">
                    <div class="card card-border">
                        <div class="card-header-premium">
                            <i class="ri-history-line"></i> سجل عملياتك
                        </div>
                        <div class="card-body p-4">
                            <div id="paymentHistoryContainer">
                                <p class="text-center text-gray py-5">جاري تحميل السجل...</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>
</div>

<script>
    // إعدادات الـ API
    var API_URL = '/api.php'; 
    var USER_DATA = {
        id: '{{ user.id }}' || 'guest',
        username: '{{ user.username }}' || 'Guest',
        email: '{{ user.email }}' || 'No Email'
    };

    var paymentMethods = {
        syriacash: { name: 'Syriacash', phone: '09XXXXXXXX', owner: 'Hussein Omran', region: 'سوريا' },
        syriatelecom: { name: 'Syriatel Cash', phone: '09XXXXXXXX', owner: 'Hussein Omran', region: 'سوريا' },
        shamcash: { name: 'Sham Cash', phone: '09XXXXXXXX', owner: 'Hussein Omran', region: 'سوريا' },
        haram: { name: 'Haram Transfer', phone: '09XXXXXXXX', owner: 'Hussein Omran', region: 'سوريا' },
        fouad: { name: 'Fouad Transfer', phone: '09XXXXXXXX', owner: 'Hussein Omran', region: 'سوريا' },
        qadmos: { name: 'Qadmos Transfer', phone: '09XXXXXXXX', owner: 'Hussein Omran', region: 'سوريا' },
        binance: { name: 'Binance (USDT)', phone: 'Wallet Address Here', owner: 'Hussein Omran', region: 'Crypto' }
    };

    var currentCurrency = 'usd';

    function updatePaymentUI() {
        var method = document.getElementById('payment_method').value;
        var infoBox = document.getElementById('exchangePaymentInfo');
        if (!method) { infoBox.style.display = 'none'; return; }
        
        var data = paymentMethods[method];
        document.getElementById('exchangePhone').textContent = data.phone;
        document.getElementById('exchangeName').textContent = data.owner;
        document.getElementById('exchangeRegion').textContent = data.region;
        infoBox.style.display = 'block';
    }

    function switchCurrency(currency) {
        currentCurrency = currency;
        document.getElementById('currency_type').value = currency;
        document.querySelectorAll('.currency-btn-enhanced').forEach(btn => btn.classList.remove('active'));
        document.querySelector(`[data-currency="${currency}"]`).classList.add('active');
        document.getElementById('currencySymbol').textContent = currency === 'usd' ? '$' : 'ل.س';
        updateCurrencyCalculation();
    }

    function updateCurrencyCalculation() {
        var amount = parseFloat(document.getElementById('payment_amount').value) || 0;
        var box = document.getElementById('currencyCalcBox');
        if (amount > 0) {
            var rate = 15000; // سعر الصرف
            var result = currentCurrency === 'usd' ? (amount * rate).toLocaleString() + ' ل.س' : (amount / rate).toFixed(2) + ' $';
            document.getElementById('exchangeRate').textContent = `1 USD = ${rate.toLocaleString()} SYP`;
            document.getElementById('localAmount').textContent = result;
            box.style.display = 'block';
        } else { box.style.display = 'none'; }
    }

    function handleFileSelect(event) {
        var file = event.target.files[0];
        if (file) {
            document.getElementById('fileName').textContent = file.name;
            document.getElementById('fileNameDisplay').style.display = 'block';
            document.getElementById('uploadPlaceholder').style.display = 'none';
        }
    }

    function copyToClipboard(text) {
        navigator.clipboard.writeText(text).then(() => showNotification('✅ تم النسخ بنجاح', 'success'));
    }

    function showNotification(msg, type) {
        var container = document.getElementById('notificationContainer');
        var div = document.createElement('div');
        div.className = `notification p-3 mb-2 rounded shadow-sm animate__animated animate__fadeInRight`;
        div.innerHTML = msg;
        container.appendChild(div);
        setTimeout(() => div.remove(), 4000);
    }

    function loadPaymentHistory() {
        fetch(`${API_URL}?action=get_user_history&user_id=${USER_DATA.id}`)
            .then(res => res.json())
            .then(data => {
                var container = document.getElementById('paymentHistoryContainer');
                if (data.status === 'success' && data.history.length > 0) {
                    var html = '';
                    data.history.forEach(item => {
                        var statusClass = `status-${item.status}`;
                        var statusIcon = item.status === 'pending' ? '⏳' : (item.status === 'approved' ? '✅' : '❌');
                        html += `
                            <div class="payment-history-item">
                                <div class="payment-header">
                                    <span class="font-weight-bold">${item.method}</span>
                                    <span class="payment-date">${item.date}</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="amount-value">${item.amount} ${item.currency}</span>
                                    <span class="${statusClass} small font-weight-bold">${statusIcon} ${item.statusText}</span>
                                </div>
                                ${item.reason ? `<div class="mt-2 small p-2 rounded bg-dark text-warning">السبب: ${item.reason}</div>` : ''}
                            </div>
                        `;
                    });
                    container.innerHTML = html;
                } else {
                    container.innerHTML = '<p class="text-center text-gray py-5">لا توجد عمليات سابقة</p>';
                }
            }).catch(() => {
                document.getElementById('paymentHistoryContainer').innerHTML = '<p class="text-center text-danger py-5">خطأ في الاتصال بالـ API</p>';
            });
    }

    document.getElementById('addFundsForm').addEventListener('submit', function(e) {
        e.preventDefault();
        var btn = e.target.querySelector('button[type="submit"]');
        btn.disabled = true;
        btn.textContent = 'جاري الإرسال...';

        var formData = new FormData();
        var orderId = Date.now().toString();
        var amount = document.getElementById('payment_amount').value;
        var method = document.getElementById('payment_method').value;
        var file = document.getElementById('receipt_image').files[0];

        formData.append('action', 'new_order');
        formData.append('id', orderId);
        formData.append('user_id', USER_DATA.id);
        formData.append('method', paymentMethods[method].name);
        formData.append('amount', amount);
        formData.append('currency', currentCurrency.toUpperCase());

        fetch(API_URL, { method: 'POST', body: formData })
            .then(res => res.json())
            .then(data => {
                var telData = new FormData();
                telData.append('action', 'send_telegram');
                telData.append('order_id', orderId);
                telData.append('receipt_image', file);
                
                var msg = `🔔 <b>طلب شحن جديد - Hussein Omran</b>\n\n`;
                msg += `👤 <b>المستخدم:</b> ${USER_DATA.username} (ID: ${USER_DATA.id})\n`;
                msg += `💳 <b>الوسيلة:</b> ${paymentMethods[method].name}\n`;
                msg += `💰 <b>المبلغ:</b> ${amount} ${currentCurrency.toUpperCase()}\n`;
                msg += `⏰ <b>الوقت:</b> ${new Date().toLocaleString('ar-SY')}\n\n`;
                msg += `<i>رقم الطلب: ${orderId}</i>`;
                telData.append('message', msg);

                return fetch(API_URL, { method: 'POST', body: telData });
            })
            .then(() => {
                showNotification('✅ تم إرسال طلبك بنجاح، سيتم مراجعته قريباً', 'success');
                e.target.reset();
                document.getElementById('fileNameDisplay').style.display = 'none';
                document.getElementById('uploadPlaceholder').style.display = 'block';
                loadPaymentHistory();
            })
            .finally(() => {
                btn.disabled = false;
                btn.textContent = 'إرسال طلب الشحن';
            });
    });

    document.addEventListener('DOMContentLoaded', () => {
        loadPaymentHistory();
        setInterval(loadPaymentHistory, 10000);
    });
</script>

<style>
    .notification-container { position: fixed; top: 20px; left: 20px; z-index: 9999; width: 300px; }
    .text-orange { color: var(--primary-orange) !important; }
    .text-gray { color: var(--text-gray) !important; }
</style>
